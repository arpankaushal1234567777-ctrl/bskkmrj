# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (MongoDB)
MONGODB_URI=mongodb://localhost:27017/bskkmrj

# Security Secrets
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# Administrator Seeding Credentials
ADMIN_EMAIL=admin@local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_admin_password

# CORS Settings
FRONTEND_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3000

# Rate Limits (Optional Configuration)
AUTH_RATE_LIMIT_MAX=10
SUBMISSION_RATE_LIMIT_MAX=5

# SMTP Email Configuration (For OTP multi-factor authentication)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sender-gmail-account@gmail.com
SMTP_PASS=your-google-app-password-16-chars
SMTP_FROM=sender-gmail-account@gmail.com
